{
    "name": "qoliber/magento-open-source-security",
    "description": "Magento 2 security modules for Qoliber open source patches and fixes.",
    "type": "magento2-module",
    "version": "1.0.0",
    "license": "MIT",
    "keywords": [
        "magento",
        "magento2",
        "security",
        "patch",
        "module",
        "security-fix",
        "hotfix",
        "PolyShell",
        "SessionReaper",
        "CVE-2025-54236",
        "APSB25-94"
    ],
    "authors": [
        {
            "name": "qoliber",
            "email": "info@qoliber.com"
        }
    ],
    "require": {
        "qoliber/core": "*"
    },
    "autoload": {
        "files": [
            "src/polyshell-patch-module/registration.php",
            "src/session-reaper-fix-module/registration.php"
        ],
        "psr-4": {
            "Qoliber\\PolyshellPatch\\": "src/polyshell-patch-module/",
            "Qoliber\\SessionReaperFix\\": "src/session-reaper-fix-module/"
        }
    }
}
